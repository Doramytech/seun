var askChange = true;
var preventEnter = false;
var dontListenKeyEvents = false;

var swalTimeout = setTimeout(function(){}, 100);

function showBlockUI()
{
	var leftPercentage = $(document).width() < 768 ? "38%" : "46%";
	$.blockUI({ message: '<img src="'+ SITEURL + 'external/backend/images/loading.png"/>', 
		css: { border:'none',padding: '15px', backgroundColor:
		'transparent', '-webkit-border-radius': '10px', '-moz-border-radius':
		'10px',/* opacity: .5,*/ color: '#fff' , width: '90px', 'border-radius':
		'5px;', left:leftPercentage,'z-index':'999999' } });
}

function showResponse(responseText) {
	jsArray = $.parseJSON(responseText);
	
	if(jsArray.status.toLowerCase() == "success") {

		swal("Success!!!", jsArray.message, "success");

	} else {
		swal("Error!!!", jsArray.message, "error");
	}
}

function GetURLParameter(sParam)
{
    var sPageURL = window.location.search.substring(1);
    var sURLVariables = sPageURL.split('&');
    for (var i = 0; i < sURLVariables.length; i++) 
    {
        var sParameterName = sURLVariables[i].split('=');
        if (sParameterName[0] == sParam) 
        {
            return (sParameterName[1] == "PaymentGateway" || sParameterName[1] == "PaymentGateway2") ? "Payment" : sParameterName[1];
        }
    }
    return "";
}

$(document).on("change", "input[name=rbModalGatewayName]", function(){
	$(".GATEWAY1-option").hide();
	$(".GATEWAY2-option").hide();
	$("." + $("input[name=rbModalGatewayName]:checked").val().toUpperCase() + "-option").show();
});

/* Bind JQuwery Validations To Form with validations Rules */
$(document).ready(function(){
	// validate all form with jquery validate
    $("form").each(function() {
    
    	// not validate have hasValidate class
    	if (!$(this).hasClass('hasValidate')) {    
    		$(this).validate({
    			invalidHandler: function(form, validator) {
    		        var errors = validator.numberOfInvalids();
    		        if (errors) {                    
    		            validator.errorList[0].element.focus();
    		            $('html, body').animate({
    		                scrollTop: $(validator.errorList[0].element).offset().top - $(".header").height() - 120
    		            }, 500);
    		        }
    		    }
    		});
    	}
    });
	
	if(SHOWONLINEFUND == "No") {
		$(".btnAddFundOnline").hide();
	}
	
	if(GetURLParameter("showDuePopUp") == "Yes") {
		$("#lblAdminDuePayments").click();	
	}
	
	$("input[name=rbModalGatewayName]").trigger("change");

    if(typeof(table) != "undefined") {
    	$.fn.dataTable.ext.errMode = 'none';
		$(document).on( 'error.dt', table, function ( e, settings, techNote, message ) {
			message = message.replace("DataTables warning: table id=DataTables_Table_0 - ", "");
			swal("Error!!!", message, "error");
		});
	}
    jQuery.validator.setDefaults({
		debug: false,
		ignore:":hidden:not(.required)",
		ignoreTitle : true,
		/*highlight: function(element) {
	        var id_attr = "#" + $( element ).attr("id") + "1";
	        $(element).closest('.form-group').removeClass('has-success').addClass('has-error');
	        $(id_attr).removeClass('glyphicon-ok').addClass('glyphicon-remove');    
	    },
	    unhighlight: function(element) {
	        var id_attr = "#" + $( element ).attr("id") + "1";
	        $(element).closest('.form-group').removeClass('has-error').addClass('has-success');
	        $(id_attr).removeClass('glyphicon-remove').addClass('glyphicon-ok');         
	    },*/ 
	});
    jQuery.validator.addMethod("mobileCheck", function(value, element) {
		  return this.optional(element) || /^[0-9]{10}$/i.test(value);
		}, "Please enter valid mobile.");
    
	jQuery.validator.addMethod("emailCheck", function(value, element) {
		  return this.optional(element) || /^[A-Z0-9][A-Z0-9\._\-]+@(?:[A-Z0-9][A-Z0-9_\-]+)\.(?:[A-Z0-9][A-Z0-9_\-]{1,9})(?:(?:\.[A-Z0-9]{2,5})?)$/i.test(value);
		}, "Please enter valid email address.");
		
	jQuery.validator.addMethod("emailCheck1", function(value, element) {
	  return this.optional(element) || /^[A-Z0-9][A-Z0-9\._\-]+@(?:[A-Z0-9][A-Z0-9_\-]+)\.(?:[A-Z0-9][A-Z0-9_\-]{1,9})(?:(?:\.[A-Z0-9]{2,5})?)$/i.test(value);
	}, "Please enter valid email address.");
	
	/* Matches Italian postcode (CAP) */
	jQuery.validator.addMethod( "pincodeCheck", function( value, element ) {
		return this.optional( element ) || /^\d{6}$/.test( value );
	}, "Please specify a valid postal code" );
	
	/* Matches Italian postcode (CAP) */
	jQuery.validator.addMethod( "pincodeCheck", function( value, element ) {
		return this.optional( element ) || /^\d{6}$/.test( value );
	}, "Please specify a valid postal code" );
	
	/* Matches Italian postcode (CAP) */
	jQuery.validator.addMethod( "maxLength", function( value, element, params ) {
		return this.optional( element ) || value.length <= params;
	}, jQuery.validator.format("Maximum {0} characters allowed."));
	
	jQuery.validator.addMethod("checkPAN", function(value, element) {
	  return this.optional(element) || /^[A-Za-z]{5}([0-9]{4})[A-Za-z]{1}$/i.test(value);
	}, "Invalid PAN No.");
		
	jQuery.validator.addMethod("checkAdhaar", function(value, element) {
	  return this.optional(element) || /^[0-9]{4}-[0-9]{4}-[0-9]{4}$/i.test(value);
	}, "Invalid Adhaar No.");
	
	jQuery.validator.addMethod("checkGSTIN", function(value, element) {
		  return this.optional(element) || /^[0-9][0-9][A-Za-z]{5}([0-9]{4})[A-Za-z]{1}[0-9][a-z][0-9a-z]$/i.test(value);
		}, "Invalid GST No.");
	jQuery.validator.addMethod("checkCallback", function(value, element) {
		  return this.optional(element) || /^[a-z]([a-z0-9])*$/i.test(value);
		}, "Callback must start with alphabets and contains only alpha numeric value.");
	jQuery.validator.addMethod("alphanumericCheck", function(value, element) {
	      return this.optional(element) || /^[a-z0-9]+$/i.test(value);
		}, "Only letters and numbers are allowed.");
	jQuery.validator.addClassRules({
		  required: {
			required : true,	
		  },  
		  requiredCheck: {
			required : true,
		  },
		  requiredCheck1: {
		  	required : {
				depends : function(el){
					var finalReturn = false;
					$.each($(el).parents("tr").find("input"), function(k,v){
						console.log($(v).val());
						if($(v).val() != "" && $(v).val() != 0) {
							finalReturn = true;
						}
					});
				return finalReturn;
				}
			}
		  },
		  password: {
		    required: true,
		    minlength: 8,
		  },
		  
		  confirmPassword: {
			required: true,
			equalTo: "#txtPassword"
		  },
		  confirmPayoutBankAccountNo: {
			required: true,
			equalTo: "#txtPayoutBankAccountNo"
		  },
		  confirmPIN: {
			required: true,
			equalTo: "#txtPIN"
		  },
		  pin: {
			  required:true,
			  digits: true,
			  maxLength:4,
		  },
		  onlyDigits: {
			  required:true,
			  digits: true,
		  },
		  alphanumeric: {
			  required:true,
			  alphanumericCheck: true,
		  },
		  onlyDigits1: {
			  digits: true,
		  },
		  isDecimal: {
			  number: true,
		  },
		  isDecimalMinus: {
			number: true,  
		  },
		  mobileCheck: {
			  required:true,
			  mobileCheck: 10,
		  },
		  mobileCheck1: {
			  mobileCheck: 10,
		  },
		  emailCheck : {
			  required: true,
			  emailCheck : true,
		  },
		  emailCheck1 : {
			  emailCheck : true,
		  },
		  max : {
			  max: function(element){
				  return Number($(element).attr("data-max"));
			  }
		  },
		  maxLength : {
			  maxLength: function(element){
				  return Number($(element).attr("data-max"));
			  }
		  },
		  pincodeCheck: {
			  pincodeCheck: true,
		  },
		  checkPAN : {
		  	checkPAN: true
		  },
		  checkAdhaar : {
		  	checkAdhaar: true
		  },
		  checkGSTIN : {
		  	checkGSTIN : true
		  },
		  checkCallback : {
		  	checkCallback : true
		  }
		});
});

// bind keypress for accept no space in password
$(document).on('keypress', '.password',  function(e) {
	if (e.which === 32) {
		return false;
	}
});

// bind keypress for accept decimal value
$(document).on('keypress', '.isDecimal', function(e) {
	if(e.ctrlKey === true || e.metaKey === true) {
		return true;
	}
	var charCode = (e.which) ? e.which : e.keyCode;
	if (charCode != 8 && charCode != 37 && charCode != 39
			&& charCode != 46 && charCode > 31
			&& (charCode < 48 || charCode > 57)) {
		return false;
	}
	// accepts only single dot
	else {
		// If the number field already has . then don't allow to
		// enter .
		// again.
		if (e.target.value.search(/\./) > -1 && charCode == 46) {
			return false;
		}
		return true;
	}
});


// bind keypress for accept decimal value
$(document).on('keypress', '.isDecimalMinus', function(e) {
	if(e.ctrlKey === true || e.metaKey === true) {
		return true;
	}
	var charCode = (e.which) ? e.which : e.keyCode;
	if (charCode != 8 && charCode != 37 && charCode != 39
			&& charCode != 45 && (e.shiftKey === true && charCode == 95) && charCode != 46 && charCode > 31
			&& (charCode < 48 || charCode > 57)) {
		return false;
	}
	// accepts only single dot
	else {
		// If the number field already has . then don't allow to
		// enter .
		// again.
		if (e.target.value.search(/\./) > -1 && charCode == 46) {
			return false;
		}
		
		if (e.target.value.search(/\-/) > -1 && (charCode == 45 || charCode == 95)) {
			return false;
		}
		return true;
	}
});

$(document).on('keypress', '.onlyDigits, .onlyDigits1', function(e) {
	if(e.ctrlKey === true || e.metaKey === true) {
		return true;
	}
	var charCode = (e.which) ? e.which : e.keyCode;
	if (charCode != 8 && charCode != 37 && charCode != 39 && charCode > 31
			&& (charCode < 48 || charCode > 57)) {
		return false;
	}
});

$(document).on("click", ".btnReset", function() {
	$(this).parents("form").resetForm();
	$(this).parents("form").data('validator').resetForm();
	$("label.error").hide();
});

jQuery.extend(jQuery.validator.messages, {
    required: "Please enter {field}",
    remote: "Please fix this field.",
    email: "Please enter a valid email address.",
    url: "Please enter a valid URL.",
    date: "Please enter a valid date.",
    dateISO: "Please enter a valid date (ISO).",
    number: "Please enter a valid number.",
    digits: "Please enter only digits.",
    equalTo: "Please enter the same value again."
});

// message for required with data-validation-name
jQuery.validator.messages.required = function(param, input) {
	if($(input).hasClass("requiredCheck") || $(input).hasClass("requiredCheck1")) {
		var requiredMessage =  "Please select {field}";
		return requiredMessage.replace("{field}", input.hasAttribute('data-validation-name') ? input.getAttribute('data-validation-name').toLowerCase() : input.getAttribute('placeholder').toLowerCase());
	} else {
		var requiredMessage =  "Please enter {field}";
		return requiredMessage.replace("{field}", input.hasAttribute('data-validation-name') ? input.getAttribute('data-validation-name').toLowerCase() : input.getAttribute('placeholder').toLowerCase());
	}
}



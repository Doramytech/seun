window.onpageshow = function (event) {
	if (window.performance.navigation.type == 2) {
    	window.location.reload(true);
    }
};

$('form input[type="text"], form input[type="password"]').keydown(function (e) {
    if (e.keyCode == 13) {
    	if($(this).parents("form").hasClass("enterSubmit"))
    	{
    		
    	} else if($(this).parents("form").hasClass("enterSubmit1"))
    	{
    		$(".checkOTPTime").click();
    	} else {
    		var inputs = $(this).parents("form").eq(0).find(":input");
            if (inputs[inputs.index(this) + 1] != null) {                    
                inputs[inputs.index(this) + 1].focus();
            }
            e.preventDefault();
            return false;	
    	}
    }
});

$(document).on("change", ".btnMasterToggle", function(){
	var thisitm = this;
	statusChangeConfirmMessage = $(thisitm).parents("tr").find(".data-status").attr("current-status") == "Active" ? inactiveStatusChangeConfirmMessage : activeStatusChangeConfirmMessage; 
	if(askChange === true)
	{
		swal({
		    title: "Are you sure?",
		    text: statusChangeConfirmMessage,
		    icon: "warning",
		    buttons: true,
		    dangerMode: true,
		})
		    .then((willDelete) => {
		    if (willDelete) {
		    	$.ajax({
            		url: SITEURL + CONTROLLERNAME + "/toggleStatus",
            		type: 'POST',
            		data :{record_id : $(thisitm).attr("data-id"),status : $(thisitm).parents("tr").find(".data-status").attr("current-status"),_csrf : $('input[name="_csrf"]').val()},
            		beforeSend : function(){showBlockUI()},
            		success: function(response) {
            			$.unblockUI();
            			jsArray = $.parseJSON(response);
            			showResponse(response);
            			if(jsArray.status ==="success") {
            				newStatus = $(thisitm).parents("tr").find(".data-status").attr("current-status") == "Active" ? "Inactive" : "Active";
            				$(thisitm).parents("tr").find(".data-status").attr("current-status", newStatus);
            			} else {
            				askChange = false;
			            	$(thisitm).val($(thisitm).parents("tr").find(".data-status").attr("current-status")).change();
			            	setTimeout(function(){askChange = true;}, 500);
            			}
        			}
				});
		    } else {
		    	askChange = false;
            	$(thisitm).val($(thisitm).parents("tr").find(".data-status").attr("current-status")).change();
            	setTimeout(function(){askChange = true;}, 500);
		    }
		  });
	}
});

$(document).on("click", ".btnGenerateRandomToken", function btnGenerateRandomToken(){
	len = 30;
	arr = '123456789abcdefghijklmnopqrstuvwxyzABCDEFGHJKLMNPQRSTUVWXYZ';
	var ans = ''; 
    for (var i = len; i > 0; i--) { 
        ans +=  
          arr[Math.floor(Math.random() * arr.length)]; 
    } 
    $("#txtAPIToken").val(ans).prop("readonly", true);
});

var stopSelect2Popup = false
$(document).on('focus', '.select2', function() {
	if(stopSelect2Popup === false)
    {
    	stopSelect2Popup = true;
    	//$(this).siblings('select').select2('open');
	}
});

$(document).on('select2:select', '.select2', function () {
   setTimeout(function(){
   		stopSelect2Popup = false;
   }, 100);
});

$(document).on('select2:close', '.select2', function () {
   setTimeout(function(){
   		stopSelect2Popup = false;
   }, 100);
});

$(document).on("keydown", "body", function(e){
	if(dontListenKeyEvents === true) {
		e.preventDefault();
		return;
	}
	
	if(e.keyCode == 13 && preventEnter === true) {		
		e.preventDefault();
		swalTimeout = setTimeout(function(){
			if(preventEnter === true && document.activeElement.tagName == "BUTTON") {
				document.activeElement.click();
			}
		}, 100);
	}
});
$(document).on("keyup keydown keypress", "input", function(e){
	clearTimeout(swalTimeout);
	if((e.keyCode == 13 || e.which == 13) && preventEnter === true && document.activeElement.className == "swal-content__input") {
		dontListenKeyEvents = true;
		setTimeout(function(){
			dontListenKeyEvents = false;
		}, 100)
		e.preventDefault();
		return false;
	}
});


/*     
 * Add collapse and remove events to boxes
 */
$("[data-card-widget='collapse']").click(function() {
	var box = $(this).parents(".card").first();
    //Find the body and the footer
    var bf = box.find(".card-body, .card-footer");
    if (!box.hasClass("collapsed-card")) {
        box.addClass("collapsed-card");
        bf.slideUp("slow");
    } else {
        box.removeClass("collapsed-card");
        bf.slideDown("slow");
    }
});

$(document).on("change", "#cmbTransferAmountExchangeType", function(){
	$(".lblTransferAmountDailylimit").text($("option:selected", this).attr("data-daily-limit"));
	
	$("#txtModalTransferAmountChargeType").val($("option:selected", this).attr("data-charge-type"));
	$("#txtModalTransferAmountCharge").val(Number($("option:selected", this).attr("data-charge")));
	$("#txtModalTransferAmountBonusType").val($("option:selected", this).attr("data-margin-type"));
	$("#txtModalTransferAmountBonus").val(Number($("option:selected", this).attr("data-margin")));
	
	$("#txtModalTransferAmount").trigger("keyup");
});

$(document).on("keyup","#txtModalTransferAmount", function(){
	chargeAmount = Number($("#txtModalTransferAmountCharge").val());
	bonusAmount = Number($("#txtModalTransferAmountBonus").val());	
	amount = Number($(this).val());
	
	if($("#txtModalTransferAmountChargeType").val() == "Percentage") {		
		chargeAmount = Number((amount * chargeAmount)/100);
	}
	
	if($("#txtModalTransferAmountBonusType").val() == "Percentage") {
		bonusAmount = Number((amount * bonusAmount)/100);
	}
	
	netAmount = Number($(this).val());
	if(netAmount > 0)
	{
		netAmount += Number(bonusAmount);
		netAmount -= Number(chargeAmount);
	}
	$("#txtModalTransferAmountNetAmount").val(Number(netAmount));
});

$(document).on("click", ".btnWalletTransferModalButton", function () {
	if(!$("#frmWalletTrasnfer").valid())
	{
		return false;
	}
	var thisitm = this;
	swal({
	    title: "Are you sure?",
	    text: "Do you want to exchange your balance ?",
	    icon: "warning",
	    buttons: true,
	    dangerMode: true,
	})
    .then((willDelete) => {
	    if (willDelete) {
	    	$.ajax({
	    		url: $("#frmWalletTrasnfer").attr("action"),
	    		type: 'POST',
	    		data :{
	    			amount : $("#txtModalTransferAmount").val(),
	    			cmbExchangeType : $("#cmbTransferAmountExchangeType").val(),
	    			pin : $("#txtModalTransferAmountPIN").val(),
	    			_csrf : $('input[name="_csrf"]').val()
    			},
	    		beforeSend : function(){
	    			if(Number( $("#txtModalTransferAmount").val()) > 0)
	    			{
	    				showBlockUI()
	    			} else {
	    				swal("OOPS!!!", "Please enter valid amount.", "error");
	    				return false;
	    			}
	    			
    			},
	    		success: function(response) {
	    			$.unblockUI();
	    			jsArray = $.parseJSON(response);
	    			showResponse(response);
	    			if(jsArray.status ==="success") {
	    				$(thisitm).parents("tr").remove();
	    			}
				}
			});
	    }
    });
});

function price_in_words(price) {
  var sglDigit = ["Zero", "One", "Two", "Three", "Four", "Five", "Six", "Seven", "Eight", "Nine"],
    dblDigit = ["Ten", "Eleven", "Twelve", "Thirteen", "Fourteen", "Fifteen", "Sixteen", "Seventeen", "Eighteen", "Nineteen"],
    tensPlace = ["", "Ten", "Twenty", "Thirty", "Forty", "Fifty", "Sixty", "Seventy", "Eighty", "Ninety"],
    handle_tens = function(dgt, prevDgt) {
      return 0 == dgt ? "" : " " + (1 == dgt ? dblDigit[prevDgt] : tensPlace[dgt])
    },
    handle_utlc = function(dgt, nxtDgt, denom) {
      return (0 != dgt && 1 != nxtDgt ? " " + sglDigit[dgt] : "") + (0 != nxtDgt || dgt > 0 ? " " + denom : "")
    };

  var str = "",
    digitIdx = 0,
    digit = 0,
    nxtDigit = 0,
    words = [];
  if (price += "", isNaN(parseInt(price))) str = "";
  else if (parseInt(price) > 0 && price.length <= 10) {
    for (digitIdx = price.length - 1; digitIdx >= 0; digitIdx--) switch (digit = price[digitIdx] - 0, nxtDigit = digitIdx > 0 ? price[digitIdx - 1] - 0 : 0, price.length - digitIdx - 1) {
      case 0:
        words.push(handle_utlc(digit, nxtDigit, ""));
        break;
      case 1:
        words.push(handle_tens(digit, price[digitIdx + 1]));
        break;
      case 2:
        words.push(0 != digit ? " " + sglDigit[digit] + " Hundred" + (0 != price[digitIdx + 1] && 0 != price[digitIdx + 2] ? " and" : "") : "");
        break;
      case 3:
        words.push(handle_utlc(digit, nxtDigit, "Thousand"));
        break;
      case 4:
        words.push(handle_tens(digit, price[digitIdx + 1]));
        break;
      case 5:
        words.push(handle_utlc(digit, nxtDigit, "Lakh"));
        break;
      case 6:
        words.push(handle_tens(digit, price[digitIdx + 1]));
        break;
      case 7:
        words.push(handle_utlc(digit, nxtDigit, "Crore"));
        break;
      case 8:
        words.push(handle_tens(digit, price[digitIdx + 1]));
        break;
      case 9:
        words.push(0 != digit ? " " + sglDigit[digit] + " Hundred" + (0 != price[digitIdx + 1] || 0 != price[digitIdx + 2] ? " and" : " Crore") : "")
    }
    str = words.reverse().join("")
  } else str = "";
  return str

}


$(document).on("click", ".btnAddFundOnline", function () {
	if(CHECK_KYC_ON_PAYMENT_GATEWAY == "Yes") {
		if($(this).attr("data-kyc-status") == "Verified") {
			$("#frmAddFundOnline").resetForm();
			$("#modal-add-fund-online").modal("show");
		} else {
			swal("Error!!!", "Please verify your KYC details to use this feature.", "error");
		}
	} else {
		$("#frmAddFundOnline").resetForm();
		$("#modal-add-fund-online").modal("show");
	}
});

$(document).on("change", "#cmbModalPaymentMode, #cmbModalBalanceType, #txtModalAddAmount", function(){

	gatewayName = typeof($("input[name=rbModalGatewayName]:checked") == "undefined") ? "gateway1" : $("input[name=rbModalGatewayName]:checked").val(); 
	$("#txtModalAddFundBonus").val($("#cmbModalBalanceType").attr($("#cmbModalBalanceType").val().toString().toLowerCase() + "-bonus-" + gatewayName.toString().toLowerCase()));
	bonus = $("#txtModalAddFundBonus").val() == "" ? 0 : Number($("#txtModalAddFundBonus").val());
	amount = Number($("#txtModalAddAmount").val());
	charge = Number($("option:selected", $("#cmbModalPaymentMode")).attr("data-charge"));
	
	chargeAmount = charge == 0 || amount == 0 ? 0 : ((amount * charge) / 100);
	bonusAmount = Number(bonus) == 0 || Number(amount) == 0 ? 0 : ((amount - chargeAmount) * bonus) / 100

	$("#txtModalAddFundSurcharge").val(charge.toFixed(2));
	
	$("#txtModalAddFundSurchargeValue").val(chargeAmount.toFixed(2));
	$("#txtModalAddFundBonusValue").val(bonusAmount.toFixed(2));
	$("#txtModalAddFundNetAmount").val(Number(Number(amount) - Number(chargeAmount)).toFixed(2));
	bonusAmount = isNaN(bonusAmount) ? 0 : Number(bonusAmount); 
	$("#txtModalAddFundReceivableAmount").val(Number(Number(amount) - Number(chargeAmount) + Number(bonusAmount)).toFixed(2));
});

$(document).on("click", ".btnAddFundModalButton", function () {
	if(!$("#frmAddFundOnline").valid())
	{
		return false;
	}
	var thisitm = this;
	swal({
	    title: "Are you sure?",
	    text: "Do you want to add fund ?",
	    icon: "warning",
	    buttons: true,
	    dangerMode: true,
	})
    .then((willDelete) => {
	    if (willDelete) {
	    	$.ajax({
	    		url: $("#frmAddFundOnline").attr("action"),
	    		type: 'POST',
	    		data :{amount : $("#txtModalAddAmount").val(),cmbBalanceType: $("#cmbModalBalanceType").val(), paymentMode: $("#cmbModalPaymentMode").val(), pin: $("#txtModalPIN").val(), _csrf : $('input[name="_csrf"]').val(), gatewayType: $("input[name=rbModalGatewayName]:checked").val()},
	    		beforeSend : function(){
	    			$("#modal-add-fund-online").modal("hide");
	    			showBlockUI();
    			},
	    		success: function(response) {
	    			$.unblockUI();
	    			jsArray = $.parseJSON(response);
	    			
	    			if(jsArray.status ==="success" && jsArray.data.gatewayName == "Paytm") {
	    				onScriptLoad(jsArray.data.orderID, jsArray.data.token, jsArray.data.orderAmount, jsArray.data.paymentId);
	    			} else if(jsArray.status ==="success" && jsArray.data.gatewayName == "RazorPay") {
	    				
	    				var options = {
				            "key": jsArray.data.token, // Enter the Key ID generated from the Dashboard
				            "name": SITE_NAME, //your business name
				            "image": LOGO_URL,
				            "order_id": jsArray.data.gatewayPaymentId, //This is a sample Order ID. Pass the `id` obtained in the response of Step 1
			                "prefill": { //We recommend using the prefill parameter to auto-fill customer's contact information especially their phone number
						        "name": jsArray.data.personName, //your customer's name
						        "email": jsArray.data.email,
						        "contact": jsArray.data.mobileNo //Provide the customer's phone number for better conversion rates 
						    },
						    "config" : {
								"display": {
									"hide" : [
							          {
							          	"method": "card"
							          },
							          {
							          	"method": "netbanking"
							          },
							          {
							          	"method": "wallet"
							          },
							          {
							          	"method": "paylater"
							          }
							        ]
								}
							}
				        };
				        var rzp1 = new Razorpay(options);
				        rzp1.open();
	    			} else if(jsArray.status ==="success" && jsArray.data.gatewayName == "Cashfree") {
	    				
	    				let checkoutOptions = {
						    paymentSessionId: jsArray.data.token,
						    redirectTarget: "_self"
						}
						
						cashfree.checkout(checkoutOptions);
	    			} else if(jsArray.status ==="success" && (jsArray.data.gatewayName == "CCAvenue" || jsArray.data.gatewayName == "SabPaisa")) {
						//$(document).html(jsArray.data.HTML);
						
						var x=window.open();
						x.document.open();
						x.document.write(jsArray.data.HTML);
						x.document.close();

					} else if(jsArray.status ==="success") {
	    				window.location.replace(jsArray.data.url, true);	
	    			} else {
	    				showResponse(response);
    				}
				}
			});
	    }
    });
});


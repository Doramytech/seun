function getAdminNotifications()
{
	if(typeof(startDate) != "undefined")
	{
		$.ajax({
			url: SITEURL + "resources/getAdminNotifications",
			type: 'POST',
			data : {lastTime : startDate, _csrf: $('input[name="_csrf"]').val()},
			success: function(response) {
				jsArray = $.parseJSON(response);
				if(jsArray.status != "success") {
					showResponse(response);
				} else {
					$.each (jsArray.data, function(k,v) {
						$(".notification" + k).hide();
						if(v > 0) {
							$(".notification" + k + " span.badge").text(v);
							$(".notification" + k).show();
							
						}
						
					});
				}
				setTimeout(function(){
			    	getAdminNotifications();
			    }, 30000);
			}
		});
	}
}

$(function() {
    setTimeout(function(){
    	getAdminNotifications();
    }, 30000);
});
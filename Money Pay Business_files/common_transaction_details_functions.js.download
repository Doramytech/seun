function  loadAEPSTransactionDetails(aepsID){
	$.ajax({
		url: SITEURL + "user/our_services/getAEPSTransactionDetails",
		type: 'POST',
		data : {aepsId : aepsID, _csrf: $('input[name="_csrf"]').val()},
		beforeSend : function(){showBlockUI()},
		success: function(response) {
			$.unblockUI();
			jsArray = $.parseJSON(response);
			if(jsArray.status.toLowerCase() == "success")
			{
				txnData = jsArray.data;
				$(".lblAEPSTransactionType").text(txnData.AepsMode);
				
				$(".lblAEPSResultTransactionID").text(txnData.transactionID);
				$(".lblAEPSResultAEPSMode").text(txnData.AepsMode);
				$(".lblAEPSResultDateTime").text(txnData.DateTime);
				$(".lblAEPSResultBankName").text(txnData.BankName);
				$(".lblAEPSResultBankRRN").text(txnData.rrnNo);
				$(".lblAEPSResultTranasctionStatus").text(txnData.status);
				$(".lblAEPSResultTransactionAmount").text(txnData.txnAmount);
				$(".lblAEPSResultACBalance").text(txnData.accountBalance);
				$(".lblAEPSResultResponseMessage").text(txnData.responseMessage);
				$(".lblAEPSResultCustomerMobileNo").text(txnData.customerMobile);
				$(".lblAEPSResultCustomerAdhaarNo").text(txnData.adhaarNumber);
				$(".lblAEPSResultAgentID").text(txnData.agentId);
				$(".lblAEPSResultAgentName").text(txnData.agentName);
				$(".lblAEPSResultAgentLocation").text(txnData.agentLocation);
				$(".imgAEPSResultPoweredBy").attr('src', "/external/backend/images/services/ic_" + txnData.providerName + ".png");
				
				if(txnData.AepsMode == "Mini Statement")
				{
					$.each(txnData.statement, function(k,v){
						$(".listMiniStatement tbody").append("<tr><td>Date : </td><td>"+ v.Date +"</td></tr>");
						$(".listMiniStatement tbody").append("<tr><td>Txn Type : </td><td>"+ v.TxnType +"</td></tr>");
						$(".listMiniStatement tbody").append("<tr><td>Amount : </td><td>"+ v.Amount +"</td></tr>");
						$(".listMiniStatement tbody").append("<tr><td>Narration : </td><td>"+ v.Remark +"</td></tr>");
						$(".listMiniStatement tbody").append("<tr><td colspan='2'>&nbsp;</td></tr>");
						$(".listResultMiniStatement").show();
					});				
				} else {
					$(".listResultMiniStatement").hide();
				}
				
				$("#aepsTranasctionDetailsPopup").modal("show");	
			} else {
				showResponse(response);
			}			
			isProcessing = false;
		}, 
		error: function(xhr, error, thrown){
			$.unblockUI();
			if(xhr.status == "401") {
            	window.location.href = SITEURL + CONTROLLERNAME;
            }else {
            	swal("Error!!!", xhr.status +":"+ xhr.statusText, "error");
			}
			isProcessing = false;
		}
	});
}


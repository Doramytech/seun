function  loadRechargeTransactionDetails(rechargeID){
	$.ajax({
		url: SITEURL + "user/our_services/getRechargeTransactionDetails",
		type: 'POST',
		data : {rechargeId : rechargeID, _csrf: $('input[name="_csrf"]').val()},
		beforeSend : function(){showBlockUI()},
		success: function(response) {
			$.unblockUI();
			jsArray = $.parseJSON(response);
			if(jsArray.status.toLowerCase() == "success")
			{
				txnData = jsArray.data;
				$(".lblRechargeTransactionType").text(txnData.ServiceType);
				$(".rechargeReceiptTable tbody").empty();
				$(".rechargeReceiptTable tbody").append("<tr><td colspan='2'><b>Transaction Details</b></td></tr>");
				
				$.each(txnData.Details, function(k,v){
					$(".rechargeReceiptTable tbody").append("<tr><td>"+ v.key +"</td><td>"+ v.value +"</td></tr>");
				});				
				
				$("#rechargeTranasctionDetailsPopup").modal("show");	
			} else {
				showResponse(response);
			}			
			isProcessing = false;
		}, 
		error: function(xhr, error, thrown){
			$.unblockUI();
			if(xhr.status == "401") {
            	window.location.href = SITEURL + CONTROLLERNAME;
            }else {
            	swal("Error!!!", xhr.status +":"+ xhr.statusText, "error");
			}
			isProcessing = false;
		}
	});
}

$(document).on("click", ".btnAEPSPrint", function(){
	//var divToPrint=document.getElementById('DivIdToPrint');
	var newWin=window.open('','Print-Window');
	newWin.document.open();
	newWin.document.write('<html><body onload="window.print(); window.close()">'+ $("#aepsTranasctionDetailsPopup .modal-body").html()+'</body></html>');
	newWin.document.close();
});

